# =============================
# CONFIGURACIÓN DE SUPABASE
# =============================
# Copia este archivo a .env.local y reemplaza los valores

# URL del proyecto Supabase
VITE_SUPABASE_URL=https://your-project-url.supabase.co

# Clave anónima (pública) - De Settings > API > Publishable Key
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# SECRET KEY (privada) - De Settings > API > Service Role Secret
# ⚠️ NUNCA la expongas al cliente o en repositorios públicos
SUPABASE_SECRET_KEY=your-service-role-key-here

# Puerto del servidor
PORT=3000

# Ambiente
NODE_ENV=development
